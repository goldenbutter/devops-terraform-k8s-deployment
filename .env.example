# Copy this file to .env and fill in your values.
# Never commit the .env file — it is excluded via .gitignore.

# Docker Hub credentials (used by scripts/docker-push.sh)
DOCKER_USERNAME=goldenbutter
DOCKER_PASSWORD=your_docker_hub_token_here

# AWS configuration (used by Terraform)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# EC2 SSH key pair name (must exist in the target AWS region)
TF_VAR_key_name=your-key-pair-name
TF_VAR_allowed_ssh_cidr=YOUR_IP/32
